{
  "name": "savanasoft/seo-sitemap",
  "description": "A powerful, flexible PHP library for generating SEO sitemaps — XML, Image, Video, News and Sitemap Index.",
  "keywords": [
    "sitemap",
    "seo",
    "xml-sitemap",
    "sitemap-index",
    "image-sitemap",
    "video-sitemap",
    "news-sitemap"
  ],
  "homepage": "https://github.com/dfdesign",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Savana Soft",
      "email": "info@savana-soft.com",
      "homepage": "https://savana-soft.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-dom": "*",
    "ext-libxml": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "DevBG\\SeoSitemap\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DevBG\\SeoSitemap\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src --level=8",
    "cs": "phpcs src tests --standard=PSR12"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.x-dev"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
